<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="512" height="512">
  <!-- Background circle -->
  <rect width="512" height="512" rx="100" fill="#ff5994"/>
  <!-- Gradient overlay -->
  <rect width="512" height="512" rx="100" fill="url(#grad)"/>
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ff9668;stop-opacity:0.6"/>
      <stop offset="100%" style="stop-color:#ff5994;stop-opacity:0"/>
    </linearGradient>
  </defs>
  <!-- Toilet emoji style -->
  <text x="256" y="320" font-size="280" text-anchor="middle" font-family="Apple Color Emoji,Segoe UI Emoji,sans-serif">🚽</text>
  <!-- Star -->
  <text x="370" y="160" font-size="120" text-anchor="middle" font-family="Apple Color Emoji,Segoe UI Emoji,sans-serif">⭐</text>
</svg>
